# Copy this file to .env and adjust if needed. Defaults below match a
# standard local Ollama install and the qwen2.5-coder model you've pulled.

# Which Ollama model to use for planner, coder, and reviewer agents.
OLLAMA_MODEL=qwen2.5-coder:7b

# Where the Ollama daemon is listening (default is correct for a normal
# local install on Windows/macOS/Linux).
OLLAMA_BASE_URL=http://localhost:11434

# Where the generated website files get written.
OUTPUT_DIR=./output/site

# Max coder<->reviewer retry loops before forcing a pass to the tester.
MAX_RETRIES=3
